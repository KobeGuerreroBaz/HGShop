---
import { urlFor } from '../lib/sanity';

interface Props {
  titulo: string;
  precio: number;
  imagenPrincipal: any;
  edicion?: string;
}

const { titulo, precio, imagenPrincipal, edicion } = Astro.props;

const NUMERO_WHATSAPP = "521XXXXXXXXXX"; // cambia esto por tu numero real

const mensaje = `Hola, me interesa: ${titulo}${edicion ? ` (${edicion})` : ''}`;
const linkWhatsApp = `https://wa.me/${NUMERO_WHATSAPP}?text=${encodeURIComponent(mensaje)}`;

const imageUrl = urlFor(imagenPrincipal).width(400).height(400).fit('crop').url();
---
<div class="flex-shrink-0 w-56 snap-start">
  <div class="aspect-square w-full overflow-hidden rounded-lg bg-neutral-50 border border-neutral-100">
    <img
      src={imageUrl}
      alt={titulo}
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>
  <h3 class="mt-3 text-sm font-medium text-neutral-900 line-clamp-2">{titulo}</h3>
  <p class="mt-1 text-base font-semibold text-neutral-900">${precio} MXN</p>
  <a
    href={linkWhatsApp}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-2 inline-flex w-full items-center justify-center rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 transition-colors"
  >
    Comprar por WhatsApp
  </a>
</div>
