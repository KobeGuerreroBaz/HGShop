---
import { sanityClient } from '../lib/sanity';
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';

// Traemos todos los productos del departamento "bebes", con su categoria incluida
const productos = await sanityClient.fetch(`
  *[_type == "producto"]{
    titulo,
    precio,
    estado,
    descripcion,
    imagenPrincipal,
    edicion,
    "categoriaTitulo": categoria->titulo,
    "categoriaDepartamento": categoria->departamento
  }
`);

// Filtramos solo bebes por ahora, y agrupamos por categoria
const productosBebes = productos.filter((p: any) => p.categoriaDepartamento === 'bebes');

const productosPorCategoria = productosBebes.reduce((acc: any, producto: any) => {
  const cat = producto.categoriaTitulo || 'Sin categoría';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(producto);
  return acc;
}, {});

const categorias = Object.keys(productosPorCategoria);
---
<Layout titulo="HG Shop MX - Catálogo">
  <section class="px-6 py-16 text-center max-w-2xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-neutral-900">
      Catálogo HG Shop
    </h1>
    <p class="mt-3 text-neutral-500">
      Busca el producto que necesitas y pídelo directo por WhatsApp
    </p>
  </section>

  <main class="px-6 pb-20 max-w-5xl mx-auto space-y-12">
    {categorias.map((cat) => (
      <section>
        <h2 class="text-lg font-semibold text-neutral-900 capitalize mb-4">{cat}</h2>
        <div class="flex gap-4 overflow-x-auto snap-x pb-2 -mx-1 px-1">
          {productosPorCategoria[cat].map((producto: any) => (
            <ProductCard
              titulo={producto.titulo}
              precio={producto.precio}
              imagenPrincipal={producto.imagenPrincipal}
              edicion={producto.edicion}
            />
          ))}
        </div>
      </section>
    ))}

    {categorias.length === 0 && (
      <p class="text-center text-neutral-400">Todavía no hay productos cargados.</p>
    )}
  </main>
</Layout>
