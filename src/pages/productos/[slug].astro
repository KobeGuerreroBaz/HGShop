---
import { sanityClient, urlFor } from '../../lib/sanity';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const productos = await sanityClient.fetch(`
    *[_type == "producto" && defined(slug.current)]{
      "slug": slug.current
    }
  `);

  return productos.map((producto: any) => ({
    params: { slug: producto.slug },
  }));
}

const { slug } = Astro.params;

const producto = await sanityClient.fetch(
  `*[_type == "producto" && slug.current == $slug][0]{
    titulo,
    precio,
    estado,
    descripcion,
    imagenPrincipal,
    galeria,
    edicion,
    capacidad,
    marca,
    edadRecomendada,
    palabrasClave,
    "categoriaTitulo": categoria->titulo
  }`,
  { slug }
);

const NUMERO_WHATSAPP = "528119651959";
const mensaje = `Hola, me interesa: ${producto.titulo}${producto.edicion ? ` (${producto.edicion})` : ''}`;
const linkWhatsApp = `https://wa.me/${NUMERO_WHATSAPP}?text=${encodeURIComponent(mensaje)}`;

const imagenPrincipalUrl = urlFor(producto.imagenPrincipal).width(800).height(800).fit('crop').url();

const galeria = (producto.galeria || []).map((img: any) => ({
  miniatura: urlFor(img).width(200).height(200).fit('crop').url(),
  completa: urlFor(img).width(800).height(800).fit('crop').url(),
}));

const todasLasFotos = [
  { miniatura: urlFor(producto.imagenPrincipal).width(200).height(200).fit('crop').url(), completa: imagenPrincipalUrl },
  ...galeria,
];
---
<Layout titulo={`${producto.titulo} - HG Shop MX`}>
  <main class="px-6 py-12 max-w-3xl mx-auto">
    <a href="/" class="text-sm text-neutral-500 hover:text-neutral-900">&larr; Volver al catálogo</a>

    <div class="mt-6 grid md:grid-cols-2 gap-10">
      <div>
        <div class="aspect-square w-full overflow-hidden rounded-xl bg-neutral-50 border border-neutral-100">
          <img id="imagen-principal" src={imagenPrincipalUrl} alt={producto.titulo} class="w-full h-full object-cover" />
        </div>

        {todasLasFotos.length > 1 && (
          <div class="mt-3 grid grid-cols-4 gap-2">
            {todasLasFotos.map((foto) => (
              <button
                type="button"
                class="miniatura aspect-square overflow-hidden rounded-lg bg-neutral-50 border border-neutral-100 hover:border-neutral-400 transition-colors"
                data-full={foto.completa}
              >
                <img src={foto.miniatura} alt={producto.titulo} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <div>
        {producto.categoriaTitulo && (
          <p class="text-xs uppercase tracking-wide text-neutral-400">{producto.categoriaTitulo}</p>
        )}
        <h1 class="mt-1 text-2xl font-semibold text-neutral-900">{producto.titulo}</h1>
        <p class="mt-3 text-2xl font-semibold text-neutral-900">${producto.precio} MXN</p>

        {producto.descripcion && (
          <p class="mt-4 text-neutral-600 leading-relaxed">{producto.descripcion}</p>
        )}

        <dl class="mt-6 space-y-2 text-sm">
          {producto.marca && (
            <div class="flex gap-2"><dt class="text-neutral-400">Marca:</dt><dd class="text-neutral-700">{producto.marca}</dd></div>
          )}
          {producto.estado && (
            <div class="flex gap-2"><dt class="text-neutral-400">Estado:</dt><dd class="text-neutral-700">{producto.estado}</dd></div>
          )}
          {producto.capacidad && (
            <div class="flex gap-2"><dt class="text-neutral-400">Capacidad:</dt><dd class="text-neutral-700">{producto.capacidad}</dd></div>
          )}
          {producto.edadRecomendada && (
            <div class="flex gap-2"><dt class="text-neutral-400">Edad recomendada:</dt><dd class="text-neutral-700">{producto.edadRecomendada}</dd></div>
          )}
          {producto.edicion && (
            <div class="flex gap-2"><dt class="text-neutral-400">Edición:</dt><dd class="text-neutral-700">{producto.edicion}</dd></div>
          )}
        </dl>

        <a
          href={linkWhatsApp}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex w-full items-center justify-center rounded-md bg-neutral-900 px-6 py-3 text-sm font-medium text-white hover:bg-neutral-700 transition-colors"
        >
          Comprar por WhatsApp
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  const imagenPrincipal = document.getElementById('imagen-principal') as HTMLImageElement;
  const miniaturas = document.querySelectorAll<HTMLButtonElement>('.miniatura');

  miniaturas.forEach((boton) => {
    boton.addEventListener('click', () => {
      const nuevaFoto = boton.dataset.full;
      if (nuevaFoto && imagenPrincipal) {
        imagenPrincipal.src = nuevaFoto;
      }
    });
  });
</script>
